# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=

# MiniMax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.1

# GLM (Zhipu)
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL=glm-4

# GUI-Plus (DashScope, tool-only)
GUI_PLUS_API_KEY=
GUI_PLUS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUI_PLUS_MODEL=gui-plus
# Optional: set to true/false
GUI_PLUS_VL_HIGH_RESOLUTION_IMAGES=
# Optional: set to true to include stream usage
GUI_PLUS_STREAM_INCLUDE_USAGE=
# Optional: image size controls
GUI_PLUS_IMAGE_MIN_PIXELS=
GUI_PLUS_IMAGE_MAX_PIXELS=
