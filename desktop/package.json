{
  "name": "Taco",
  "private": true,
  "version": "0.4.2",
  "description": "Taco AI - 智能编程助手",
  "author": {
    "name": "Fushengfu",
    "email": "shengfu8161980541@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fushengfu/tacoai.git"
  },
  "bugs": {
    "url": "https://github.com/Fushengfu/tacoai/issues"
  },
  "type": "module",
  "main": "dist-main/main.cjs",
  "scripts": {
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true",
    "build:main": "esbuild src/main/main.ts --bundle --platform=node --format=cjs --minify --legal-comments=none --outfile=dist-main/main.cjs --external:electron --external:node-pty",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=cjs --minify --legal-comments=none --outfile=dist-preload/index.cjs --external:electron",
    "build:renderer": "vite build",
    "build:obfuscate:optional": "node scripts/obfuscate-optional.mjs",
    "dev": "npm run build:main && npm run build:preload && concurrently -k \"vite\" \"cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron dist-main/main.cjs\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer && npm run build:obfuscate:optional",
    "build:secure": "cross-env TACO_OBFUSCATE=1 npm run build",
    "preview": "vite preview",
    "start": "npm run build:main && npm run build:preload && npm run build:renderer && electron dist-main/main.cjs",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.taco.ai-agent",
    "productName": "Taco AI",
    "electronVersion": "40.1.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-main/**/*",
      "dist-preload/**/*",
      "build/icon.*",
      "node_modules/node-pty/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true,
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ]
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@vscode/l10n": "^0.0.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dotenv": "^16.4.7",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "40.1.0",
    "electron-builder": "^26.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.14"
  }
}
